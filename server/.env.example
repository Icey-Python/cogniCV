MONGO_URI=mongodb://localhost:27017/shirikia
SERVER_PORT=8001
NODE_ENV=dev

# API Docs Auth
API_DOCS_USER=admin
API_DOCS_PASSWORD=admin
API_DOCS_SERVER=http://localhost:8001
API_DOCS_REALM=your_api_docs

# Inital Admin
ADMIN_INITIAL_PASS=my_strong_pass
ADMIN_INITIAL_EMAIL=my_admin_email

FRONTEND_URLS=http://localhost:3000,http://localhost:4200

# JWT secrets
JWT_SECRET="your_secret_key_here"

# Gemini related
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# RabbitMQ
RABBITMQ_URL=amqp://localhost

# Cloudflare R2 Storage (S3 Compatible)
R2_ACCESS_KEY_ID=your_r2_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_BUCKET_NAME=cognicv-resumes
R2_PUBLIC_DOMAIN=https://pub-your_id.r2.dev

# Minio / S3 Storage
AWS_ACCESS_KEY=appuser
AWS_SECRET=strongpassword
AWS_REGION=us-east-1
AWS_S3_BUCKET=shirikiadao
AWS_S3_ENDPOINT=https://mystorage.com

