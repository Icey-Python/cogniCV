          },
          "bio": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "skills": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "level": {
                  "type": "string",
                  "enum": [
                    "Beginner",
                    "Intermediate",
                    "Advanced",
                    "Expert"
                  ]
                },
                "yearsOfExperience": {
                  "type": "number"
                }
              }
            }
          },
          "experience": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "company": {
                  "type": "string"
                },
                "role": {
                  "type": "string"
                },
