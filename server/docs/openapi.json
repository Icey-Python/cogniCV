                },
                "endDate": {
                  "type": "string"
                },
                "isCurrent": {
                  "type": "boolean"
                }
              }
            }
          },
          "availability": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "enum": [
                  "Available",
                  "Open to Opportunities",
                  "Not Available"
                ]
              },
              "type": {
                "type": "string",
                "enum": [
                  "Full-time",
                  "Part-time",
                  "Contract"
                ]
              }
            }
          }
        }
      },
      "Job": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "requiredSkills": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "experienceLevel": {
            "type": "string",
            "enum": [
              "Entry",
              "Junior",
              "Mid",
              "Senior",
              "Lead"
            ]
          },
          "type": {
            "type": "string",
            "enum": [
              "Full-time",
              "Part-time",
              "Contract"
            ]
          },
          "location": {
            "type": "string"
          },
          "createdBy": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ScreeningResult": {
        "type": "object",
        "properties": {
          "jobId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "completed",
              "failed"
            ]
          },
          "rankedCandidates": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "rank": {
